{
  "username": "user",
  "model": {
    "provider": "openai",
    "model": "gpt-4",
    "api_key": "",
    "temperature": 0.7,
    "max_tokens": 4096
  },
  "skills_paths": [
    "./.openmercury/skills",
    "~/.config/openmercury/skills"
  ],
  "memory_enabled": true,
  "memory_path": "~/.openmercury/memory",
  "log_level": "INFO",
  "sandbox_mode": "ask"
}
